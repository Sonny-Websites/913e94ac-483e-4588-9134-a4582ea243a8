---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AboutContent from '../components/AboutContent.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Maia Bruno',
  url: 'https://example.com',
  description: 'Sitio personal de Maia Bruno',
  availableLanguage: ['es']
};
---

<BaseLayout
  title="Maia Bruno"
  description="Sitio personal de Maia Bruno para contar historias, intereses y momentos importantes. Descripción editable por la clienta."
  ogTitle="Maia Bruno"
  ogDescription="Sitio personal de Maia Bruno para contar cosas sobre ella."
  jsonLd={jsonLd}
>
  <Header current="home" />
  <AboutContent />
  <Footer />
</BaseLayout>
