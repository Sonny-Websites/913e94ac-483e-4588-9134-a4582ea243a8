---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
---

<BaseLayout
  title="Gracias"
  description="Gracias por escribirle a Maia Bruno. Tu mensaje fue enviado correctamente."
  ogTitle="Gracias - Maia Bruno"
  ogDescription="Tu mensaje fue enviado correctamente."
>
  <Header current="thank-you" />
  <section class="thank-you" role="main" aria-labelledby="thankHeading">
    <h1 id="thankHeading">Gracias</h1>
    <p>Tu mensaje se envió correctamente.</p>
    <p style="color: #62566a; font-size: 0.95rem; margin-top: 1rem;">Maia podrá responder cuando revise este formulario.</p>
    <a href={base + '/'} class="btn btn-primary" style="display: inline-block; margin-top: 2rem;">Volver al inicio</a>
  </section>
  <Footer />
</BaseLayout>
