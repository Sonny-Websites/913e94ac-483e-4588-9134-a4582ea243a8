---
interface Props {
  current?: 'home' | 'about' | 'thank-you';
}

const { current } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
const contactHref = current === 'about' ? '#contacto' : `${base}/#contacto`;
---

<header role="banner">
  <nav role="navigation" aria-label="Navegación principal">
    <a href={base + '/'} class="logo">Maia Bruno</a>
    <button class="hamburger" id="hamburgerMenu" aria-label="Abrir o cerrar menú de navegación" aria-expanded="false" aria-controls="navMenu">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <ul id="navMenu" class="nav-menu">
      <li><a href={base + '/'} aria-current={current === 'home' ? 'page' : undefined}>Inicio</a></li>
      <li><a href={base + '/about/'} aria-current={current === 'about' ? 'page' : undefined}>Sobre mí</a></li>
      <li><a href={contactHref}>Contacto</a></li>
    </ul>
  </nav>
</header>
