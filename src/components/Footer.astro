---
const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
---

<footer role="contentinfo">
  <div class="footer-content">
    <div class="footer-section">
      <h3>Enlaces</h3>
      <ul>
        <li><a href={base + '/'}>Inicio</a></li>
        <li><a href={base + '/about/'}>Sobre mí</a></li>
        <li><a href={base + '/#contacto'}>Contacto</a></li>
      </ul>
    </div>
    <div class="footer-section">
      <h3>Redes</h3>
      <div class="social-links">
        <a href="https://instagram.com" aria-label="Instagram de Maia Bruno" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="https://tiktok.com" aria-label="TikTok de Maia Bruno" target="_blank" rel="noopener noreferrer">TikTok</a>
        <a href="https://linkedin.com" aria-label="LinkedIn de Maia Bruno" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
    </div>
    <div class="footer-section">
      <h3>Contacto</h3>
      <ul>
        <li>Buenos Aires, Argentina</li>
        <li>hola@example.com</li>
        <li>Disponible para editar</li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; <span id="year">2026</span> Maia Bruno. Todos los derechos reservados.</p>
  </div>
</footer>
